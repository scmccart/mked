{
  "mcpServers": {
    "mermaid": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "--prefer-offline",
        "mcp-mermaid"
      ],
      "tools": ["*"]
    },
    "context7": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "--prefer-offline",
        "@upstash/context7-mcp"
      ],
      "tools": ["*"]
    },
    "markitdown": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "uvx",
        "markitdown-mcp"
      ],
      "tools": ["*"]
    },
    "nuget": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "dnx",
        "NuGet.Mcp.Server",
        "--source",
        "https://api.nuget.org/v3/index.json",
        "--yes"
      ],
      "tools": ["*"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}",
        "X-MCP-Toolsets": "actions,git,issues,pull_requests,repos,github_support_docs_search"
      }
    }
  }
}
