{
  "mcpServers": {
    "mermaid": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "--prefer-offline",
        "mcp-mermaid"
      ],
      "tools": ["*"]
    },
    "context7": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "--prefer-offline",
        "@upstash/context7-mcp"
      ],
      "tools": ["*"]
    },
    "markitdown": {
      "type": "local",
      "command": "uvx",
      "args": [
        "markitdown-mcp"
      ],
      "tools": ["*"]
    },
    "nuget": {
      "type": "local",
      "command": "dnx",
      "args": [
        "NuGet.Mcp.Server",
        "--source",
        "https://api.nuget.org/v3/index.json",
        "--yes"
      ],
      "tools": ["*"]
    }
  }
}
