# Enforce LF line endings for all text files in this repo.
# This aligns with the .editorconfig end_of_line = lf setting.

* text=auto eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.nupkg binary
*.snupkg binary

.github/workflows/*.lock.yml linguist-generated=true merge=ours